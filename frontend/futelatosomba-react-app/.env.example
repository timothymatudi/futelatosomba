# Futelatosomba React Frontend - Environment Variables

# Backend API URL (no trailing slash)
# For local dev, use the backend port. For production (unified Vercel deploy), use /api.
REACT_APP_API_URL=http://localhost:3001/api

# Stripe Configuration (for payments)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Optional: Google Maps API Key (if using Google Maps instead of Leaflet)
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional: Analytics
# REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Optional: Sentry Error Tracking
# REACT_APP_SENTRY_DSN=https://your-sentry-dsn-here

# Production API URL (for unified Vercel deployment, use relative path)
# REACT_APP_API_URL=/api
